{
  "components": {
    "button": {
      "description": "Primary interactive element for actions",
      "variants": {
        "size": ["xs", "sm", "default", "lg", "xl", "xxl", "icon-xs", "icon-sm", "icon", "icon-lg", "icon-xl"],
        "variant": ["default", "secondary", "outline", "ghost", "destructive", "link", "info", "success", "warning", "ai-action"],
        "state": ["default", "hover", "active", "focus", "disabled", "loading"]
      },
      "sizes": {
        "xs": {
          "height": 28,
          "paddingX": 8,
          "fontSize": 12,
          "iconSize": 14,
          "borderRadius": 12
        },
        "sm": {
          "height": 32,
          "paddingX": 12,
          "fontSize": 12,
          "iconSize": 16,
          "borderRadius": 12
        },
        "default": {
          "height": 36,
          "paddingX": 16,
          "fontSize": 14,
          "iconSize": 16,
          "borderRadius": 12
        },
        "lg": {
          "height": 40,
          "paddingX": 20,
          "fontSize": 14,
          "iconSize": 18,
          "borderRadius": 12
        },
        "xl": {
          "height": 44,
          "paddingX": 24,
          "fontSize": 16,
          "iconSize": 20,
          "borderRadius": 12
        },
        "xxl": {
          "height": 48,
          "paddingX": 28,
          "fontSize": 16,
          "iconSize": 20,
          "borderRadius": 12
        }
      },
      "styles": {
        "default": {
          "background": "linear-gradient(135deg, #5153f6, #3b82f6)",
          "text": "#ffffff",
          "border": "none",
          "shadow": "0 1px 2px rgba(0,0,0,0.05)"
        },
        "secondary": {
          "light": {
            "background": "#ffffff",
            "text": "#475569",
            "border": "1px solid #e2e8f099"
          },
          "dark": {
            "background": "#212c40",
            "text": "#94a3b8",
            "border": "1px solid #33415599"
          }
        },
        "outline": {
          "background": "transparent",
          "text": "#475569",
          "border": "1px solid #e2e8f0"
        },
        "ghost": {
          "background": "transparent",
          "text": "#475569",
          "border": "none"
        },
        "destructive": {
          "background": "linear-gradient(135deg, #ef4444, #f43f5e)",
          "text": "#ffffff",
          "border": "none"
        },
        "link": {
          "background": "transparent",
          "text": "#5153f6",
          "border": "none",
          "textDecoration": "underline"
        }
      }
    },
    "input": {
      "description": "Text input field",
      "specs": {
        "height": 36,
        "paddingX": 12,
        "paddingY": 8,
        "borderRadius": 6,
        "borderWidth": 1,
        "fontSize": 14,
        "lineHeight": 20
      },
      "states": {
        "default": {
          "light": {
            "background": "#ffffff",
            "border": "#e2e8f0",
            "text": "#0f172a",
            "placeholder": "#64748b"
          },
          "dark": {
            "background": "#1c2538",
            "border": "#334155",
            "text": "#f8fafc",
            "placeholder": "#64748b"
          }
        },
        "hover": {
          "border": "#94a3b8"
        },
        "focus": {
          "border": "#5153f6",
          "ring": "2px #5153f633"
        },
        "error": {
          "border": "#f46969"
        },
        "disabled": {
          "background": "#f8fafc",
          "border": "#e2e8f099",
          "text": "#94a3b8"
        }
      }
    },
    "textarea": {
      "description": "Multi-line text input",
      "specs": {
        "minHeight": 80,
        "padding": 12,
        "borderRadius": 6,
        "borderWidth": 1,
        "fontSize": 14,
        "lineHeight": 20
      }
    },
    "checkbox": {
      "description": "Selection control for multiple choices",
      "specs": {
        "boxSize": 16,
        "borderRadius": 4,
        "borderWidth": 1,
        "labelGap": 8,
        "labelFontSize": 14,
        "checkIconSize": 12
      },
      "states": {
        "unchecked": {
          "background": "transparent",
          "border": "#e2e8f0"
        },
        "checked": {
          "background": "#5153f6",
          "border": "#5153f6",
          "checkColor": "#ffffff"
        },
        "indeterminate": {
          "background": "#5153f6",
          "border": "#5153f6",
          "dashColor": "#ffffff"
        }
      }
    },
    "switch": {
      "description": "Toggle control for on/off states",
      "specs": {
        "trackWidth": 44,
        "trackHeight": 24,
        "trackRadius": 12,
        "thumbSize": 20,
        "thumbRadius": 10,
        "thumbOffset": 2
      },
      "states": {
        "off": {
          "track": "#e2e8f0",
          "thumb": "#ffffff",
          "thumbPosition": 2
        },
        "on": {
          "track": "#5153f6",
          "thumb": "#ffffff",
          "thumbPosition": 22
        }
      },
      "animation": {
        "duration": 200,
        "easing": "ease"
      }
    },
    "select": {
      "description": "Dropdown selection control",
      "trigger": {
        "height": 36,
        "paddingX": 12,
        "borderRadius": 6,
        "borderWidth": 1,
        "fontSize": 14,
        "chevronSize": 16
      },
      "dropdown": {
        "background": {
          "light": "#ffffff",
          "dark": "#283346"
        },
        "borderRadius": 8,
        "borderWidth": 1,
        "shadow": "0 10px 15px rgba(0,0,0,0.1)",
        "padding": 4,
        "maxHeight": 300
      },
      "option": {
        "height": 32,
        "paddingX": 8,
        "borderRadius": 4,
        "fontSize": 14,
        "checkIconSize": 16
      }
    },
    "badge": {
      "description": "Label for status or categorization",
      "specs": {
        "paddingX": 10,
        "paddingY": 2,
        "borderRadius": 9999,
        "fontSize": 12,
        "fontWeight": 500
      },
      "variants": {
        "default": {
          "background": "#e0e7ff",
          "text": "#343bb3"
        },
        "secondary": {
          "background": "#fef0fe",
          "text": "#914bb1"
        },
        "success": {
          "background": "#22c55e1a",
          "text": "#16a34a"
        },
        "warning": {
          "background": "#f59e0b1a",
          "text": "#d97706"
        },
        "error": {
          "background": "#f469691a",
          "text": "#dc2626"
        },
        "info": {
          "background": "#3b82f61a",
          "text": "#2563eb"
        }
      }
    },
    "card": {
      "description": "Container for grouped content",
      "specs": {
        "borderRadius": 12,
        "borderWidth": 0.5,
        "padding": 24
      },
      "styles": {
        "light": {
          "background": "#ffffff",
          "border": "#e2e8f099",
          "shadow": "0 1px 3px rgba(15,23,42,0.08)"
        },
        "dark": {
          "background": "#1c2538",
          "border": "#33415599",
          "shadow": "0 1px 3px rgba(0,0,0,0.4)"
        }
      },
      "sections": {
        "header": {
          "paddingBottom": 16,
          "borderBottom": "0.5px solid",
          "titleFontSize": 18,
          "titleFontWeight": 600,
          "descFontSize": 14
        },
        "footer": {
          "paddingTop": 16,
          "borderTop": "0.5px solid"
        }
      }
    },
    "dialog": {
      "description": "Modal dialog for focused interactions",
      "overlay": {
        "background": "rgba(0,0,0,0.8)",
        "backdropBlur": 4
      },
      "container": {
        "borderRadius": 16,
        "maxWidth": {
          "default": 425,
          "lg": 600,
          "xl": 800
        },
        "maxHeight": "85vh"
      },
      "styles": {
        "light": {
          "background": "#ffffff",
          "shadow": "0 25px 50px rgba(15,23,42,0.2)"
        },
        "dark": {
          "background": "#212c40",
          "shadow": "0 25px 50px rgba(0,0,0,0.7)"
        }
      },
      "spacing": {
        "header": { "padding": "24px 24px 16px" },
        "content": { "padding": "0 24px" },
        "footer": { "padding": "16px 24px 24px" }
      },
      "closeButton": {
        "position": { "top": 16, "right": 16 },
        "size": 32,
        "iconSize": 16
      },
      "animation": {
        "enter": {
          "opacity": { "from": 0, "to": 1 },
          "scale": { "from": 0.95, "to": 1 },
          "duration": 150
        },
        "exit": {
          "opacity": { "from": 1, "to": 0 },
          "scale": { "from": 1, "to": 0.95 },
          "duration": 150
        }
      }
    },
    "dropdownMenu": {
      "description": "Contextual menu with actions",
      "container": {
        "minWidth": 160,
        "padding": 4,
        "borderRadius": 8,
        "borderWidth": 1
      },
      "item": {
        "height": 32,
        "paddingX": 8,
        "paddingLeft": 32,
        "borderRadius": 4,
        "fontSize": 14,
        "iconSize": 16
      },
      "separator": {
        "height": 1,
        "marginY": 4
      },
      "groupLabel": {
        "padding": 8,
        "fontSize": 12,
        "fontWeight": 600,
        "textTransform": "uppercase"
      }
    },
    "accordion": {
      "description": "Expandable content sections",
      "trigger": {
        "padding": 16,
        "fontSize": 14,
        "fontWeight": 500,
        "borderBottom": "1px solid",
        "chevronSize": 16
      },
      "content": {
        "padding": 16
      },
      "animation": {
        "duration": 200,
        "easing": "ease-out"
      }
    },
    "alert": {
      "description": "Inline notification message",
      "specs": {
        "padding": 16,
        "borderRadius": 8,
        "borderWidth": 1,
        "iconSize": 16,
        "gap": 12
      },
      "typography": {
        "titleFontSize": 14,
        "titleFontWeight": 500,
        "descFontSize": 14
      },
      "variants": {
        "info": {
          "background": "#3b82f61a",
          "border": "#3b82f64d",
          "iconColor": "#2563eb"
        },
        "success": {
          "background": "#22c55e1a",
          "border": "#22c55e4d",
          "iconColor": "#16a34a"
        },
        "warning": {
          "background": "#f59e0b1a",
          "border": "#f59e0b4d",
          "iconColor": "#d97706"
        },
        "error": {
          "background": "#f469691a",
          "border": "#f469694d",
          "iconColor": "#dc2626"
        }
      }
    },
    "progress": {
      "description": "Progress indicator",
      "linear": {
        "trackHeight": 8,
        "trackRadius": 4,
        "trackBackground": "#e2e8f0",
        "fillBackground": "#5153f6",
        "fillRadius": 4
      },
      "circular": {
        "size": 40,
        "strokeWidth": 4,
        "trackColor": "#e2e8f0",
        "fillColor": "#5153f6"
      }
    },
    "tabs": {
      "description": "Tab navigation component",
      "list": {
        "padding": 4,
        "gap": 4,
        "borderRadius": 8
      },
      "trigger": {
        "height": 32,
        "paddingX": 12,
        "borderRadius": 6,
        "fontSize": 14,
        "fontWeight": 500
      },
      "states": {
        "default": {
          "background": "transparent",
          "text": "#475569"
        },
        "hover": {
          "background": "#f8fafc",
          "text": "#0f172a"
        },
        "active": {
          "light": {
            "background": "#ffffff",
            "text": "#0f172a",
            "shadow": "0 1px 2px rgba(0,0,0,0.05)"
          },
          "dark": {
            "background": "#212c40",
            "text": "#f8fafc",
            "shadow": "0 1px 2px rgba(0,0,0,0.2)"
          }
        }
      },
      "content": {
        "paddingTop": 16
      }
    },
    "panel": {
      "description": "Side panel for details/editing",
      "container": {
        "widths": {
          "sm": 256,
          "md": 320,
          "lg": 384,
          "xl": 512
        },
        "borderLeft": "0.5px solid"
      },
      "header": {
        "padding": 24,
        "borderBottom": "0.5px solid"
      },
      "content": {
        "padding": 24,
        "paddingBottom": 96
      },
      "footer": {
        "position": "sticky",
        "padding": "16px 24px",
        "borderTop": "1px solid"
      }
    },
    "navigationList": {
      "description": "Vertical navigation menu",
      "item": {
        "height": 40,
        "paddingX": 12,
        "borderRadius": 8,
        "gap": 12,
        "iconSize": 20,
        "fontSize": 14,
        "fontWeight": 500
      },
      "states": {
        "default": {
          "background": "transparent",
          "text": "#475569",
          "icon": "#64748b"
        },
        "hover": {
          "light": { "background": "#f8fafc" },
          "dark": { "background": "#1c2538" }
        },
        "active": {
          "background": "#5153f61a",
          "text": "#5153f6",
          "icon": "#5153f6"
        }
      }
    },
    "statusBadge": {
      "description": "Status indicator with dot",
      "specs": {
        "height": 24,
        "paddingX": 10,
        "borderRadius": 6,
        "dotSize": 6,
        "gap": 6,
        "fontSize": 12,
        "fontWeight": 500
      },
      "variants": {
        "active": {
          "background": "#22c55e1a",
          "dot": "#22c55e",
          "text": "#16a34a"
        },
        "pending": {
          "background": "#f59e0b1a",
          "dot": "#f59e0b",
          "text": "#d97706"
        },
        "failed": {
          "background": "#f469691a",
          "dot": "#f46969",
          "text": "#dc2626"
        },
        "inactive": {
          "background": "#f1f5f9",
          "dot": "#94a3b8",
          "text": "#475569"
        },
        "running": {
          "background": "#3b82f61a",
          "dot": "#3b82f6",
          "text": "#2563eb",
          "dotAnimation": "pulse 2s infinite"
        }
      }
    }
  },
  "icons": {
    "library": "lucide-react",
    "version": "0.323.0",
    "sizes": {
      "xs": 14,
      "sm": 16,
      "md": 18,
      "lg": 20,
      "xl": 24
    },
    "commonIcons": [
      { "name": "Layers", "usage": "Feature" },
      { "name": "Box", "usage": "Sub-feature" },
      { "name": "Package", "usage": "Product" },
      { "name": "ChevronRight", "usage": "Navigation, Expand" },
      { "name": "ChevronDown", "usage": "Collapse, Dropdown" },
      { "name": "Plus", "usage": "Add action" },
      { "name": "X", "usage": "Close, Remove" },
      { "name": "Sparkles", "usage": "AI features" },
      { "name": "CheckCircle2", "usage": "Success, Selected" },
      { "name": "AlertCircle", "usage": "Warning, Error" },
      { "name": "Info", "usage": "Information" },
      { "name": "Sun", "usage": "Light mode" },
      { "name": "Moon", "usage": "Dark mode" },
      { "name": "Link2", "usage": "Links, Connections" },
      { "name": "ExternalLink", "usage": "External links" },
      { "name": "Search", "usage": "Search" },
      { "name": "Settings", "usage": "Settings" },
      { "name": "User", "usage": "User, Profile" },
      { "name": "LogOut", "usage": "Logout" },
      { "name": "MoreHorizontal", "usage": "More options" },
      { "name": "MoreVertical", "usage": "More options vertical" },
      { "name": "Edit", "usage": "Edit action" },
      { "name": "Trash2", "usage": "Delete action" },
      { "name": "Copy", "usage": "Copy action" },
      { "name": "Check", "usage": "Confirm, Done" },
      { "name": "AlertTriangle", "usage": "Warning" },
      { "name": "Eye", "usage": "View, Visibility" },
      { "name": "EyeOff", "usage": "Hide" },
      { "name": "Filter", "usage": "Filter" },
      { "name": "Download", "usage": "Download" },
      { "name": "Upload", "usage": "Upload" },
      { "name": "RefreshCw", "usage": "Refresh, Sync" },
      { "name": "ArrowLeft", "usage": "Back" },
      { "name": "ArrowRight", "usage": "Forward" },
      { "name": "Home", "usage": "Home" },
      { "name": "Folder", "usage": "Folder" },
      { "name": "File", "usage": "File" },
      { "name": "FileText", "usage": "Document" },
      { "name": "Code", "usage": "Code" },
      { "name": "Terminal", "usage": "Terminal, CLI" },
      { "name": "GitBranch", "usage": "Branch" },
      { "name": "GitCommit", "usage": "Commit" },
      { "name": "GitPullRequest", "usage": "Pull Request" }
    ]
  }
}
